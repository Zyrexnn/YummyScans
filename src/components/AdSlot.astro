---
interface Props {
  width: number
  height: number
  adKey: string
  class?: string
}

const { width, height, adKey, class: className } = Astro.props
const uid = Math.random().toString(36).slice(2, 10)
---

<div class:list={[className]} style={`min-width:${width}px;min-height:${height}px;display:flex;justify-content:center;overflow:hidden;`}>
  <div id={`ad-${uid}`} style={`width:${width}px;height:${height}px;`}></div>
  <script is:inline define:vars={{ adKey, width, height, uid }}>
    (function() {
      var el = document.getElementById('ad-' + uid);
      if (!el) return;
      var q = window._adQueue = window._adQueue || Promise.resolve();
      window._adQueue = q.then(function() {
        return new Promise(function(resolve) {
          window.atOptions = { key: adKey, format: 'iframe', height: height, width: width, params: {} };
          var s = document.createElement('script');
          s.src = 'https://delvefencescrewdriver.com/' + adKey + '/invoke.js';
          s.async = false;
          s.onload = function() { setTimeout(resolve, 500); };
          s.onerror = function() { setTimeout(resolve, 500); };
          el.appendChild(s);
        });
      });
    })();
  </script>
</div>

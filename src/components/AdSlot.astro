---
interface Props {
  width: number
  height: number
  adKey: string
  class?: string
}

const { width, height, adKey, class: className } = Astro.props
const uid = `ad-${adKey}`
---

<div class:list={[className]} style={`min-width:${width}px;min-height:${height}px;display:flex;justify-content:center;overflow:hidden;`}>
  <div id={uid} style={`width:${width}px;height:${height}px;`}></div>
  <script is:inline define:vars={{ adKey, width, height, uid }}>
    if (!window['_adLoaded_' + adKey]) {
      window['_adLoaded_' + adKey] = true;
      atOptions = { 'key': adKey, 'format': 'iframe', 'height': height, 'width': width, 'params': {} };
      var s = document.createElement('script');
      s.src = 'https://delvefencescrewdriver.com/' + adKey + '/invoke.js';
      s.async = true;
      var c = document.getElementById(uid);
      if (c) c.appendChild(s);
    }
  </script>
</div>

---
interface Props {
  width: number
  height: number
  adKey: string
  class?: string
}

const { width, height, adKey, class: className } = Astro.props
const adsEnabled = import.meta.env.PUBLIC_ADS_ENABLED !== 'false'
---

<div class:list={[className]} style={`min-width:${width}px;min-height:${height}px;display:flex;justify-content:center;overflow:hidden;`}>
  <div id={`ad-${adKey}`} style={`width:${width}px;height:${height}px;`}></div>
  {adsEnabled && (
    <script is:inline define:vars={{ adKey, width, height }}>
      (function() {
        if (window['_ad_' + adKey]) return;
        window['_ad_' + adKey] = true;
        var container = document.getElementById('ad-' + adKey);
        if (!container) return;
        // Sandbox the ad in an iframe so its document.write can't blank the page.
        var iframe = document.createElement('iframe');
        iframe.width = width;
        iframe.height = height;
        iframe.scrolling = 'no';
        iframe.frameBorder = '0';
        iframe.style.border = '0';
        container.appendChild(iframe);
        var doc = iframe.contentWindow.document;
        doc.open();
        doc.write(
          '<html><head><style>body{margin:0}</style></head><body>' +
          '<script type="text/javascript">' +
          'atOptions = ' + JSON.stringify({ key: adKey, format: 'iframe', height: height, width: width, params: {} }) + ';' +
          '<\/script>' +
          '<script type="text/javascript" src="https://www.highperformanceformat.com/' + adKey + '/invoke.js"><\/script>' +
          '</body></html>'
        );
        doc.close();
      })();
    </script>
  )}
</div>

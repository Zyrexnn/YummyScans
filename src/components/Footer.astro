---
const currentYear = new Date().getFullYear()
---

<footer class="bg-background border-t border-border transition-theme">
  <div class="max-w-[1280px] mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-12">
      {/* Brand */}
      <div class="md:col-span-4">
        <a href="/" class="flex items-center gap-2.5 group no-underline">
          <div class="w-9 h-9 bg-primary rounded-[10px] flex items-center justify-center">
            <svg class="w-5 h-5 text-primary-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <span class="text-[22px] font-bold tracking-tight text-foreground">YummyScans</span>
        </a>
        <p class="text-sm mt-4 text-muted-foreground leading-relaxed max-w-xs">
          Platform baca komik manga, manhwa, dan manhua Sub Indo terbaik. Gratis tanpa iklan.
        </p>
      </div>

      {/* Navigasi */}
      <div class="md:col-span-2">
        <h4 class="text-caption text-muted-foreground mb-4">Navigasi</h4>
        <ul class="flex flex-col gap-2.5 list-none p-0 m-0">
          <li><a href="/" class="text-sm font-medium hover:text-foreground/60 transition-colors text-foreground no-underline">Beranda</a></li>
          <li><a href="/search" class="text-sm font-medium hover:text-foreground/60 transition-colors text-foreground no-underline">Cari Manga</a></li>
          <li><a href="/genre" class="text-sm font-medium hover:text-foreground/60 transition-colors text-foreground no-underline">Genre</a></li>
          <li><a href="/latest" class="text-sm font-medium hover:text-foreground/60 transition-colors text-foreground no-underline">Terbaru</a></li>
        </ul>
      </div>

      {/* Genre Populer */}
      <div class="md:col-span-3">
        <h4 class="text-caption text-muted-foreground mb-4">Genre Populer</h4>
        <div class="flex flex-wrap gap-2">
          {['Action', 'Romance', 'Comedy', 'Fantasy', 'Drama', 'Sports'].map((genre) => (
            <a
              href={`/genre/${genre.toLowerCase()}`}
              class="text-xs font-medium px-3 py-1.5 rounded-[8px] bg-secondary hover:bg-primary hover:text-primary-foreground transition-all duration-200 text-foreground no-underline"
            >
              {genre}
            </a>
          ))}
        </div>
      </div>

      {/* Lainnya */}
      <div class="md:col-span-3">
        <h4 class="text-caption text-muted-foreground mb-4">Lainnya</h4>
        <ul class="flex flex-col gap-2.5 list-none p-0 m-0">
          <li><a href="/about" class="text-sm font-medium hover:text-foreground/60 transition-colors text-foreground no-underline">Tentang Kami</a></li>
          <li><a href="/contact" class="text-sm font-medium hover:text-foreground/60 transition-colors text-foreground no-underline">Kontak</a></li>
          <li><a href="/privacy" class="text-sm font-medium hover:text-foreground/60 transition-colors text-foreground no-underline">Kebijakan Privasi</a></li>
          <li><a href="/admin" class="text-sm font-medium hover:text-foreground/60 transition-colors text-foreground no-underline">Admin</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-16 pt-8 border-t border-border">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-caption text-muted-foreground">
          &copy; {currentYear} YummyScans. All rights reserved.
        </p>
      </div>
    </div>
  </div>
</footer>

---
const currentYear = new Date().getFullYear()
---

<footer class="bg-[#0a0a0b] border-t border-white/10 transition-theme">
  <div class="max-w-[1280px] mx-auto px-6 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-12 gap-8 lg:gap-12">
      <div class="lg:col-span-4">
        <a href="/" class="flex items-center gap-2.5 group no-underline">
          <div class="w-9 h-9 bg-white rounded-[10px] flex items-center justify-center">
            <svg class="w-5 h-5 text-black" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <span class="text-[22px] font-bold tracking-tight text-white">YummyScans</span>
        </a>
        <p class="text-sm mt-4 text-white/50 leading-relaxed max-w-xs">
          Platform baca komik manga, manhwa, dan manhua Sub Indo terbaik. Gratis tanpa iklan.
        </p>
      </div>

      <div class="lg:col-span-2">
        <h4 class="text-[11px] font-mono uppercase tracking-wider text-white/40 mb-4">Navigasi</h4>
        <ul class="flex flex-col gap-2.5 list-none p-0 m-0">
          <li><a href="/" class="text-sm font-medium text-white/60 hover:text-white transition-colors no-underline">Beranda</a></li>
          <li><a href="/search" class="text-sm font-medium text-white/60 hover:text-white transition-colors no-underline">Cari Manga</a></li>
          <li><a href="/genre" class="text-sm font-medium text-white/60 hover:text-white transition-colors no-underline">Genre</a></li>
          <li><a href="/latest" class="text-sm font-medium text-white/60 hover:text-white transition-colors no-underline">Terbaru</a></li>
          <li><a href="/library" class="text-sm font-medium text-white/60 hover:text-white transition-colors no-underline">Library</a></li>
        </ul>
      </div>

      <div class="lg:col-span-3">
        <h4 class="text-[11px] font-mono uppercase tracking-wider text-white/40 mb-4">Genre Populer</h4>
        <div class="flex flex-wrap gap-2">
          {['Action', 'Romance', 'Comedy', 'Fantasy', 'Drama', 'Horror', 'Thriller', 'Slice of Life'].map((genre) => (
            <a
              href={`/genre/${genre.toLowerCase().replace(/\s+/g, '-')}`}
              class="text-xs font-medium px-3 py-1.5 rounded-[8px] bg-white/10 hover:bg-white/20 text-white/60 hover:text-white transition-all duration-200 no-underline"
            >
              {genre}
            </a>
          ))}
        </div>
      </div>

      <div class="lg:col-span-3">
        <h4 class="text-[11px] font-mono uppercase tracking-wider text-white/40 mb-4">Ikuti Kami</h4>
        <div class="flex gap-3">
          <a href="#" class="flex h-9 w-9 items-center justify-center rounded-full bg-white/10 text-white/60 hover:bg-white/20 hover:text-white transition-all no-underline">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="#" class="flex h-9 w-9 items-center justify-center rounded-full bg-white/10 text-white/60 hover:bg-white/20 hover:text-white transition-all no-underline">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="#" class="flex h-9 w-9 items-center justify-center rounded-full bg-white/10 text-white/60 hover:bg-white/20 hover:text-white transition-all no-underline">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
          </a>
          <a href="#" class="flex h-9 w-9 items-center justify-center rounded-full bg-white/10 text-white/60 hover:bg-white/20 hover:text-white transition-all no-underline">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-white/10">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-[12px] text-white/40">
          &copy; {currentYear} YummyScans. All rights reserved.
        </p>
        <div class="flex gap-4 text-[12px] text-white/40">
          <a href="#" class="hover:text-white transition-colors no-underline">Kebijakan Privasi</a>
          <a href="#" class="hover:text-white transition-colors no-underline">Syarat & Ketentuan</a>
          <a href="#" class="hover:text-white transition-colors no-underline">Kontak</a>
        </div>
      </div>
    </div>
  </div>
</footer>

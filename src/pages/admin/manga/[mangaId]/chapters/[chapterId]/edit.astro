---
import AdminLayout from '../../../../../../layouts/AdminLayout.astro'
import { getMangaBySlug } from '../../../../../../lib/manga'
import { getChapterById, updateChapter } from '../../../../../../lib/chapter'
import { uploadChapterPages } from '../../../../../../lib/storage'
import { getAdminClient } from '../../../../../../lib/supabase-server'

const slug = Astro.params.mangaId
const chapterId = Astro.params.chapterId
let manga: any = null
let chapter: any = null
let error: string | null = null

try {
  ;[manga, chapter] = await Promise.all([getMangaBySlug(slug), getChapterById(chapterId)])
} catch (e: any) {
  error = e.message || 'Gagal memuat'
}

if (Astro.request.method === 'POST' && chapter) {
  try {
    const form = await Astro.request.formData()
    const title = String(form.get('title') || '')
    const files = form.getAll('pages') as File[]
    const sb = await getAdminClient(Astro.cookies)
    const payload: any = { title }
    if (files.length > 0 && files[0].size > 0) {
      const pages = await uploadChapterPages(sb, manga.id, `ch${chapter.chapter_number}`, files)
      payload.pages = pages
    }
    await updateChapter(sb, chapterId, payload)
    return Astro.redirect(`/admin/manga/${slug}/chapters`)
  } catch (e: any) {
    error = e.message || 'Gagal menyimpan'
  }
}
---

<AdminLayout active="Komik" title="Edit Chapter">
  <div class="mx-auto max-w-2xl px-6 py-8">
    <a href={`/admin/manga/${slug}/chapters`} class="text-xs text-black/50 hover:underline">← Chapter</a>
    <h1 class="mb-6 text-2xl font-bold text-black">Edit Chapter {chapter?.chapter_number}</h1>

    {error && <div class="mb-4 rounded-xl border border-red-300 bg-red-50 px-4 py-3 text-sm text-red-700">{error}</div>}

    {chapter ? (
      <form method="POST" enctype="multipart/form-data" class="space-y-5">
        <div>
          <label class="mb-1.5 block text-sm font-semibold text-black">Judul Chapter</label>
          <input name="title" value={chapter.title || ''} class="w-full rounded-xl border border-black/15 px-4 py-2.5 text-sm text-black focus:outline-none focus:ring-2 focus:ring-black/20" />
        </div>
        <div>
          <label class="mb-1.5 block text-sm font-semibold text-black">Ganti Halaman (opsional)</label>
          <input type="file" name="pages" accept="image/*" multiple class="block w-full text-sm text-black/70 file:mr-3 file:rounded-pill file:border-0 file:bg-black file:px-4 file:py-2 file:text-white" />
          <p class="mt-1 text-xs text-black/50">{chapter.page_count} halaman saat ini.</p>
        </div>
        <button type="submit" class="rounded-pill bg-black px-6 py-2.5 text-sm font-semibold text-white transition hover:opacity-90">Simpan</button>
      </form>
    ) : (
      <p class="text-sm text-black/50">Chapter tidak ditemukan.</p>
    )}
  </div>
</AdminLayout>

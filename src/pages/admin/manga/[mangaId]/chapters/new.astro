---
import AdminLayout from '../../../../../layouts/AdminLayout.astro'
import { getMangaBySlug } from '../../../../../lib/manga'
import { createChapter } from '../../../../../lib/chapter'
import { uploadChapterPages } from '../../../../../lib/storage'

const slug = Astro.params.mangaId
let manga: any = null
let error: string | null = null

try {
  manga = await getMangaBySlug(slug)
} catch (e: any) {
  error = e.message || 'Gagal memuat manga'
}

if (Astro.request.method === 'POST' && manga) {
  try {
    const form = await Astro.request.formData()
    const chapterNumber = parseFloat(String(form.get('chapter_number') || '0'))
    const title = String(form.get('title') || '')
    const files = form.getAll('pages') as File[]

    if (!chapterNumber || files.length === 0) {
      error = 'Nomor chapter dan minimal 1 halaman wajib diisi.'
    } else {
      const pages = await uploadChapterPages(manga.id, `ch${chapterNumber}`, files)
      await createChapter(manga.id, { chapter_number: chapterNumber, title, pages })
      return Astro.redirect(`/admin/manga/${slug}/chapters`)
    }
  } catch (e: any) {
    error = e.message || 'Gagal menyimpan chapter'
  }
}
---

<AdminLayout active="Manga" title="Tambah Chapter">
  <div class="mx-auto max-w-2xl px-6 py-8">
    <a href={`/admin/manga/${slug}/chapters`} class="text-xs text-black/50 hover:underline">← Chapter</a>
    <h1 class="mb-6 text-2xl font-bold text-black">Tambah Chapter{manga ? ` — ${manga.title}` : ''}</h1>

    {error && <div class="mb-4 rounded-xl border border-red-300 bg-red-50 px-4 py-3 text-sm text-red-700">{error}</div>}

    <form method="POST" enctype="multipart/form-data" class="space-y-5">
      <div>
        <label class="mb-1.5 block text-sm font-semibold text-black">Nomor Chapter</label>
        <input type="number" step="0.1" name="chapter_number" required class="w-full rounded-xl border border-black/15 px-4 py-2.5 text-sm text-black focus:outline-none focus:ring-2 focus:ring-black/20" />
      </div>
      <div>
        <label class="mb-1.5 block text-sm font-semibold text-black">Judul Chapter</label>
        <input name="title" class="w-full rounded-xl border border-black/15 px-4 py-2.5 text-sm text-black focus:outline-none focus:ring-2 focus:ring-black/20" placeholder="Opsional" />
      </div>
      <div>
        <label class="mb-1.5 block text-sm font-semibold text-black">Halaman (gambar)</label>
        <input type="file" name="pages" accept="image/*" multiple required class="block w-full text-sm text-black/70 file:mr-3 file:rounded-pill file:border-0 file:bg-black file:px-4 file:py-2 file:text-white" />
        <p class="mt-1 text-xs text-black/50">Minimal 1 file, maks 5MB/file.</p>
      </div>
      <button type="submit" class="rounded-pill bg-black px-6 py-2.5 text-sm font-semibold text-white transition hover:opacity-90">Simpan Chapter</button>
    </form>
  </div>
</AdminLayout>

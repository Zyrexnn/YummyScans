---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import { getMangaList, deleteManga } from '../../../lib/manga'
import { supabase } from '../../../db/supabase'

let manga: any[] = []
let total = 0
let error: string | null = null
let notice: string | null = null

const page = parseInt(Astro.url.searchParams.get('page') || '1', 10)
const limit = 12

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const id = form.get('id')
  if (id) {
    try {
      await deleteManga(id)
      notice = 'Manga berhasil dihapus.'
    } catch (e: any) {
      error = e.message || 'Gagal menghapus'
    }
  }
}

try {
  const { manga: list, count } = await getMangaList({ page, limit })
  const withCounts = await Promise.all(
    list.map(async (m: any) => {
      const { count: ch } = await supabase
        .from('chapters')
        .select('*', { count: 'exact', head: true })
        .eq('manga_id', m.id)
      const genres = (m.manga_genres || []).map((g: any) => g.genres?.name).filter(Boolean)
      return { ...m, chapterCount: ch || 0, genres }
    })
  )
  manga = withCounts
  total = count || manga.length
} catch (e: any) {
  error = e.message || 'Gagal memuat manga'
}
const totalPages = Math.max(1, Math.ceil(total / limit))
const statusStyle: Record<string, string> = {
  ongoing: 'bg-black/5 text-black/70',
  completed: 'bg-black text-white',
  hiatus: 'bg-black/10 text-black/70',
}
---

<AdminLayout active="Manga" title="Manga">
  <div class="mx-auto max-w-5xl px-6 py-8">
    <div class="mb-6 flex items-center justify-between">
      <h1 class="text-3xl font-bold text-black">Manga</h1>
      <a href="/admin/manga/new" class="rounded-pill bg-black px-5 py-2.5 text-sm font-semibold text-white transition hover:opacity-90">+ Tambah Manga</a>
    </div>

    {error && <div class="mb-4 rounded-xl border border-red-300 bg-red-50 px-4 py-3 text-sm text-red-700">{error}</div>}
    {notice && <div class="mb-4 rounded-xl border border-black/10 bg-black/5 px-4 py-3 text-sm text-black">{notice}</div>}

    <div class="overflow-hidden rounded-2xl border border-black/10">
      <table class="w-full text-left">
        <thead>
          <tr class="border-b border-black/10 text-xs uppercase tracking-wide text-black/50">
            <th class="px-4 py-3 font-medium">Cover</th>
            <th class="px-4 py-3 font-medium">Judul</th>
            <th class="px-4 py-3 font-medium">Status</th>
            <th class="px-4 py-3 font-medium">Genre</th>
            <th class="px-4 py-3 font-medium">Chapter</th>
            <th class="px-4 py-3 font-medium text-right">Aksi</th>
          </tr>
        </thead>
        <tbody>
          {manga.map((m, i) => (
            <tr class={'align-middle ' + (i !== manga.length - 1 ? 'border-b border-black/10' : '')}>
              <td class="px-4 py-3">
                <img src={m.cover_url} alt="" class="h-12 w-10 rounded-md object-cover" onerror="this.style.display='none'" />
              </td>
              <td class="px-4 py-3 font-bold text-black">{m.title}</td>
              <td class="px-4 py-3">
                <span class={'rounded-full px-3 py-1 text-xs font-medium capitalize ' + (statusStyle[m.status] || 'bg-black/5 text-black/70')}>{m.status}</span>
              </td>
              <td class="px-4 py-3 font-mono text-[11px] uppercase tracking-wide text-black/60">{m.genres.join(', ')}</td>
              <td class="px-4 py-3 text-sm text-black/70">{m.chapterCount}</td>
              <td class="px-4 py-3">
                <div class="flex justify-end gap-2">
                  <a href={`/admin/manga/${m.slug}/edit`} class="flex h-9 w-9 items-center justify-center rounded-full border border-black/15 text-black transition hover:bg-black/5" aria-label="Edit">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M4 20h4L18.5 9.5a2.12 2.12 0 0 0-3-3L5 17v3z" /></svg>
                  </a>
                  <form method="POST" class="inline">
                    <input type="hidden" name="id" value={m.id} />
                    <button type="submit" class="flex h-9 w-9 items-center justify-center rounded-full border border-black/15 text-black transition hover:bg-red-50 hover:text-red-600" aria-label="Hapus" onclick="return confirm('Hapus manga ini?')">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M4 7h16M9 7V5h6v2m-9 0 1 13h8l1-13" /></svg>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          ))}
          {manga.length === 0 && (
            <tr><td colspan="6" class="px-4 py-10 text-center text-sm text-black/50">Belum ada manga.</td></tr>
          )}
        </tbody>
      </table>
    </div>

    {totalPages > 1 && (
      <div class="mt-6 flex items-center justify-center gap-2">
        {page > 1 && <a href={`/admin/manga?page=${page - 1}`} class="rounded-lg border border-black/15 px-3 py-2 text-sm text-black hover:bg-black/5">‹</a>}
        <span class="rounded-lg bg-black px-3 py-2 text-sm font-semibold text-white">{page}</span>
        {page < totalPages && <a href={`/admin/manga?page=${page + 1}`} class="rounded-lg border border-black/15 px-3 py-2 text-sm text-black hover:bg-black/5">›</a>}
      </div>
    )}
  </div>
</AdminLayout>

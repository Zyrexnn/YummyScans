---
import EditorialLayout from '../../layouts/EditorialLayout.astro'
import MangaCard from '../../components/MangaCard'
import { fetchGenreManga, fetchByGenreAndType } from '../../lib/komiku'
import { ArrowLeft, ArrowRight, BookOpen, Tag } from 'lucide-react'

const TYPES = ['Semua', 'Manhwa', 'Manga', 'Manhua']
const { slug } = Astro.params
const page = parseInt(Astro.url.searchParams.get('page') || '1')
const typeFilter = Astro.url.searchParams.get('type') || ''

let mangaList: any[] = []
let error: string | null = null
let hasMore = false

const mapFn = (m: any) => ({
  id: m.slug, title: m.title, slug: m.slug, coverUrl: m.coverUrl,
  status: m.type || 'ongoing', genres: [{ id: '', name: m.type || '', slug: '' }],
})

try {
  if (!typeFilter || typeFilter === 'Semua') {
    const [currentPage, nextPage] = await Promise.all([fetchGenreManga(slug!, page), fetchGenreManga(slug!, page + 1)])
    mangaList = currentPage.map(mapFn)
    hasMore = nextPage.length > 0
  } else {
    const [currentPage, nextPage] = await Promise.all([fetchByGenreAndType(slug!, typeFilter, page), fetchByGenreAndType(slug!, typeFilter, page + 1)])
    mangaList = currentPage.map(mapFn)
    hasMore = nextPage.length > 0
  }
} catch (e: any) {
  error = e.message || 'Failed to load manga'
}

function buildUrl(params: Record<string, string>) {
  const u = new URL(Astro.url.href)
  for (const [k, v] of Object.entries(params)) {
    if (v) u.searchParams.set(k, v)
    else u.searchParams.delete(k)
  }
  u.searchParams.delete('page')
  return u.pathname + u.search
}

const genreName = slug?.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ') || ''

function pageUrl(p: number) {
  const u = new URL(Astro.url.origin + Astro.url.pathname)
  if (typeFilter && typeFilter !== 'Semua') u.searchParams.set('type', typeFilter)
  u.searchParams.set('page', String(p))
  return u.pathname + u.search
}
---

<EditorialLayout title={`${genreName} - YummyScans`} description={`Baca manga genre ${genreName} Sub Indo`}>
  <section class="section-spacing bg-background">
    <div class="max-w-[1280px] mx-auto px-6">
      <div class="mb-6">
        <a href="/genre" class="inline-flex items-center gap-2 text-sm font-medium text-muted-foreground hover:text-foreground transition-colors no-underline mb-4">
          <ArrowLeft class="w-4 h-4" /> Semua Genre
        </a>
        <div class="flex items-center gap-3 mb-2">
          <div class="w-10 h-10 bg-primary rounded-[12px] flex items-center justify-center">
            <Tag class="w-5 h-5 text-primary-foreground" />
          </div>
          <h1 class="text-display-lg">{genreName}</h1>
        </div>
      </div>

      {/* FILTERS */}
      <div class="flex items-center gap-2 mb-8 flex-wrap">
        {TYPES.map(t => {
          const val = t === 'Semua' ? '' : t
          const active = (typeFilter === val) || (!typeFilter && t === 'Semua')
          return (
            <a
              href={active ? buildUrl({}) : buildUrl({ type: val })}
              class={`rounded-full px-4 py-1.5 text-sm font-medium transition ${
                active ? 'bg-foreground text-background' : 'bg-secondary text-foreground/70 hover:bg-muted'
              }`}
            >
              {t}
            </a>
          )
        })}
      </div>

      {error ? (
        <div class="bg-secondary rounded-[24px] p-12 md:p-16 text-center">
          <div class="w-16 h-16 bg-muted rounded-full flex items-center justify-center mx-auto mb-5">
            <BookOpen class="w-8 h-8 text-muted-foreground" />
          </div>
          <p class="text-headline mb-2">Gagal memuat manga</p>
          <p class="text-body-sm text-muted-foreground mb-4">{error}</p>
          <a href={`/genre/${slug}`} class="yummy-btn-secondary inline-block">Coba Lagi</a>
        </div>
      ) : mangaList.length === 0 ? (
        <div class="bg-secondary rounded-[24px] p-12 md:p-16 text-center">
          <div class="w-16 h-16 bg-muted rounded-full flex items-center justify-center mx-auto mb-5">
            <BookOpen class="w-8 h-8 text-muted-foreground" />
          </div>
          <p class="text-headline mb-2">Tidak ada manga</p>
          <p class="text-body-sm text-muted-foreground mb-4">
            {typeFilter && typeFilter !== 'Semua'
              ? `Tidak ada ${typeFilter} di genre ${genreName}.`
              : `Genre ${genreName} belum memiliki manga.`}
          </p>
          {typeFilter && typeFilter !== 'Semua' ? (
            <a href={buildUrl({})} class="yummy-btn-secondary inline-block">Lihat Semua</a>
          ) : (
            <a href="/genre" class="yummy-btn-secondary inline-block">Kembali ke Genre</a>
          )}
        </div>
      ) : (
        <>
          <p class="text-xs text-muted-foreground mb-4">
            {typeFilter && typeFilter !== 'Semua' ? typeFilter : 'Semua'} &middot; Halaman {page}
          </p>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-5 md:gap-6">
            {mangaList.map((manga, i) => (
              <MangaCard
                client:load
                title={manga.title}
                coverUrl={manga.coverUrl}
                slug={manga.slug}
                genres={manga.genres}
                status={manga.status}
                index={i}
              />
            ))}
          </div>

          <div class="flex items-center justify-center gap-3 mt-10">
            {page > 1 && (
              <a href={pageUrl(page - 1)} class="yummy-btn-secondary inline-flex items-center gap-2">
                <ArrowLeft class="w-4 h-4" /> Sebelumnya
              </a>
            )}
            <span class="text-sm font-medium text-muted-foreground px-4">Halaman {page}</span>
            {hasMore && (
              <a href={pageUrl(page + 1)} class="yummy-btn-secondary inline-flex items-center gap-2">
                Selanjutnya <ArrowRight class="w-4 h-4" />
              </a>
            )}
          </div>
        </>
      )}
    </div>
  </section>
</EditorialLayout>

---
import EditorialLayout from '../../layouts/EditorialLayout.astro'
import { fetchGenreList } from '../../lib/komiku'
import { Swords, Mountain, Drama, Wand2, Ghost, Heart, Rocket, Coffee, Trophy, Zap, Skull, Search, BookOpen, Sparkles } from 'lucide-react'

const genreIcons: Record<string, any> = {
  'action': Swords,
  'adventure': Mountain,
  'comedy': Drama,
  'fantasy': Wand2,
  'horror': Ghost,
  'romance': Heart,
  'sci-fi': Rocket,
  'slice-of-life': Coffee,
  'sports': Trophy,
  'supernatural': Zap,
  'thriller': Skull,
  'mystery': Search,
  'drama': Drama,
  'shounen': Sparkles,
  'school-life': BookOpen,
  'seinen': BookOpen,
  'martial-arts': Swords,
}

const genreColors: Record<string, string> = {
  'action': 'bg-block-coral',
  'adventure': 'bg-block-lime',
  'comedy': 'bg-block-cream',
  'fantasy': 'bg-block-lilac',
  'horror': 'bg-block-navy',
  'romance': 'bg-block-pink',
  'sci-fi': 'bg-block-mint',
  'slice-of-life': 'bg-block-cream',
  'sports': 'bg-block-lime',
  'supernatural': 'bg-block-lilac',
  'thriller': 'bg-block-coral',
  'mystery': 'bg-block-mint',
  'drama': 'bg-block-coral',
  'shounen': 'bg-block-lime',
  'school-life': 'bg-block-cream',
  'seinen': 'bg-block-navy',
  'martial-arts': 'bg-block-coral',
}

let genres: { name: string; slug: string; count: string }[] = []
let error: string | null = null

try {
  genres = await fetchGenreList()
} catch (e: any) {
  error = e.message || 'Failed to load genres'
}
---

<EditorialLayout title="Genre - YummyScans" description="Jelajahi manga berdasarkan genre favoritmu">

  <section class="section-spacing bg-background">
    <div class="max-w-[1280px] mx-auto px-6">
      <div class="text-center mb-12">
        <div class="text-eyebrow text-muted-foreground mb-3 flex items-center justify-center gap-2">
          <Sparkles class="w-4 h-4" />
          Koleksi Lengkap
        </div>
        <h1 class="text-display-lg mb-4">Jelajahi Genre</h1>
        <p class="text-body-lg text-muted-foreground max-w-xl mx-auto">
          Temukan manga favoritmu dari berbagai genre yang tersedia.
        </p>
      </div>

      {error ? (
        <div class="bg-secondary rounded-[24px] p-12 md:p-16 text-center">
          <div class="w-16 h-16 bg-muted rounded-full flex items-center justify-center mx-auto mb-5">
            <BookOpen class="w-8 h-8 text-muted-foreground" />
          </div>
          <p class="text-headline mb-2">Gagal memuat genre</p>
          <p class="text-body-sm text-muted-foreground mb-4">{error}</p>
          <a href="/genre" class="yummy-btn-secondary inline-block">Coba Lagi</a>
        </div>
      ) : (
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-5">
          {genres.map((genre, i) => {
            const Icon = genreIcons[genre.slug] || BookOpen
            const color = genreColors[genre.slug] || 'bg-block-cream'
            return (
              <a
                href={`/genre/${genre.slug}`}
                class={`group relative overflow-hidden rounded-[20px] p-5 md:p-6 no-underline transition-all duration-300 hover:shadow-lg hover:-translate-y-1 ${color}`}
                style={`animation-delay: ${i * 50}ms`}
              >
                <div class="relative z-10">
                  <div class="w-10 h-10 bg-white/20 rounded-[12px] flex items-center justify-center mb-3">
                    <Icon class="w-5 h-5 text-foreground" />
                  </div>
                  <h3 class="text-[15px] font-bold text-foreground mb-1">{genre.name}</h3>
                  {genre.count && (
                    <p class="text-xs text-foreground/60 font-medium">{genre.count} komik</p>
                  )}
                </div>
                <div class="absolute inset-0 -translate-x-full group-hover:translate-x-full transition-transform duration-1000 bg-gradient-to-r from-transparent via-white/15 to-transparent" />
              </a>
            )
          })}
        </div>
      )}
    </div>
  </section>

</EditorialLayout>

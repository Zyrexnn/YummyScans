---
import EditorialLayout from '../layouts/EditorialLayout.astro'
import MangaCard from '../components/MangaCard'
import MarqueeStrip from '../components/MarqueeStrip'
import GLSLHills from '../components/GLSLHills'
import StatsSection from '../components/StatsSection'
import FeaturesSection from '../components/FeaturesSection'
import GenreShowcase from '../components/GenreShowcase'
import FAQSection from '../components/FAQSection'
import { fetchPopularManga } from '../lib/mangadex'
import { ArrowRight, Sparkles, TrendingUp, BookOpen, AlertCircle } from 'lucide-react'

let mangaList: any[] = []
let fetchError: string | null = null

try {
  mangaList = await fetchPopularManga(5)
} catch (error: any) {
  fetchError = error.message || 'Failed to fetch manga'
  console.error('MangaDex fetch error:', fetchError)
}
---

<EditorialLayout title="YummyScans - Baca Komik Sub Indo">

  {/* HERO */}
  <section class="relative overflow-hidden bg-background min-h-[90vh] flex items-center justify-center transition-theme">
    <GLSLHills client:load speed={0.3} cameraZ={100} />
    <div class="relative z-10 max-w-[1280px] mx-auto text-center px-6 py-24">
      <div class="inline-flex items-center gap-2 bg-white/10 dark:bg-white/10 backdrop-blur-md rounded-full px-4 py-1.5 mb-8 border border-white/20">
        <Sparkles class="w-4 h-4 text-primary" />
        <span class="text-[13px] font-semibold text-foreground/80">Gratis Tanpa Iklan</span>
      </div>

      <h1 class="text-display-xl mb-6 text-foreground">
        Baca Manga<br/>Sub Indo
      </h1>

      <p class="text-subhead mb-10 max-w-2xl mx-auto text-foreground/70">
        Jelajahi ribuan manga, manhwa, dan manhua dengan terjemahan bahasa Indonesia berkualitas tinggi.
      </p>

      <div class="flex flex-col sm:flex-row justify-center gap-4 mb-16">
        <a href="/search" class="yummy-btn-primary flex items-center justify-center gap-2">
          Mulai Baca <ArrowRight class="w-4 h-4" />
        </a>
        <a href="/genre" class="yummy-btn-secondary flex items-center justify-center">
          Jelajahi Genre
        </a>
      </div>
    </div>
  </section>

  {/* MARQUEE */}
  <MarqueeStrip client:load />

  {/* STATS */}
  <StatsSection client:load />

  {/* FEATURES */}
  <FeaturesSection client:visible />

  {/* POPULAR MANGA */}
  <section class="section-spacing bg-background transition-theme">
    <div class="max-w-[1280px] mx-auto px-6">
      <div class="flex items-end justify-between mb-10">
        <div>
          <div class="text-eyebrow text-muted-foreground mb-3 flex items-center gap-2">
            <TrendingUp class="w-4 h-4" />
            Populer
          </div>
          <h2 class="text-display-lg">Manga Populer</h2>
        </div>
      </div>

      {mangaList.length > 0 ? (
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-5 md:gap-6">
          {mangaList.map((manga, i) => (
            <MangaCard
              client:load
              title={manga.title}
              coverUrl={manga.coverUrl}
              slug={manga.slug}
              genres={manga.genres}
              status={manga.status}
              index={i}
            />
          ))}
        </div>
      ) : (
        <div class="bg-secondary rounded-[24px] p-12 md:p-16 text-center">
          <div class="w-16 h-16 bg-muted rounded-full flex items-center justify-center mx-auto mb-5">
            {fetchError ? (
              <AlertCircle class="w-8 h-8 text-destructive" />
            ) : (
              <BookOpen class="w-8 h-8 text-muted-foreground" />
            )}
          </div>
          <p class="text-headline mb-2">
            {fetchError ? 'Gagal memuat manga' : 'Tidak ada manga'}
          </p>
          <p class="text-body-sm text-muted-foreground mb-4">
            {fetchError || 'Coba refresh halaman.'}
          </p>
          <a href="/" class="yummy-btn-secondary inline-block">
            Coba Lagi
          </a>
        </div>
      )}
    </div>
  </section>

  {/* GENRE SHOWCASE */}
  <GenreShowcase client:visible />

  {/* FAQ */}
  <FAQSection client:visible />

  {/* CTA */}
  <section class="section-spacing bg-background transition-theme">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <h2 class="text-display-lg mb-6">Siap Membaca?</h2>
      <p class="text-body-lg text-muted-foreground mb-10">
        Jelajahi ribuan manga dan manhwa dengan terjemahan bahasa Indonesia yang berkualitas.
      </p>
      <a href="/search" class="yummy-btn-primary inline-flex items-center gap-2">
        Mulai Baca Sekarang <ArrowRight class="w-4 h-4" />
      </a>
    </div>
  </section>

</EditorialLayout>

---
import EditorialLayout from '../layouts/EditorialLayout.astro'
import Hero from '../components/Hero'
import TrendingSection from '../components/TrendingSection'
import PopularGrid from '../components/PopularGrid'
import UpdateSection from '../components/UpdateSection'
import Rekomendasi from '../components/Rekomendasi'

import DownloadApp from '../components/DownloadApp'
import { fetchLatest } from '../lib/komiku'
import { getMangaList, toLatestShape } from '../lib/manga'

let latestFeed: any[] = []
let projectFeed: any[] = []

try {
  const pages = await Promise.all([fetchLatest(1), fetchLatest(2), fetchLatest(3), fetchLatest(4)])
  latestFeed = pages.flat()
} catch (error: any) {
  console.error('[Home] Failed to load mirror manga:', error.message)
}

try {
  const { manga } = await getMangaList({ type: 'project', limit: 48 })
  projectFeed = (manga || []).map(toLatestShape)
} catch (error: any) {
  console.error('[Home] Failed to load project manga:', error.message)
}
---

<EditorialLayout title="YummyScans - Baca Komik Sub Indo">

  <Hero client:load manga={latestFeed} />

  <TrendingSection client:visible manga={latestFeed} />

  <PopularGrid client:visible manga={latestFeed} />

  {/* UPDATE TERBARU (Mirror + Project) */}
  <UpdateSection client:visible mirror={latestFeed} project={projectFeed} />

  {/* REKOMENDASI */}
  <Rekomendasi client:visible manga={latestFeed} />

  {/* DOWNLOAD APP */}
  <DownloadApp client:load />

</EditorialLayout>

---
import { ArrowLeft } from 'lucide-react'
import { fetchChapterPages, fetchChapterInfo, fetchMangaDetail } from '../../../lib/mangadex'

const { mangaId, chapterId } = Astro.params

let pages: { url: string; number: number }[] = []
let chapterInfo: any = null
let mangaTitle = ''
let error: string | null = null

try {
  // Fetch chapter pages
  const chapterData = await fetchChapterPages(chapterId!)
  const baseUrl = chapterData.baseUrl
  const hash = chapterData.hash

  // Use high quality pages, fallback to data saver
  const pageFiles = chapterData.pages.length > 0 ? chapterData.pages : chapterData.pagesSaver

  pages = pageFiles.map((file: string, i: number) => ({
    url: `/api/page?url=${encodeURIComponent(`${baseUrl}/data/${hash}/${file}`)}`,
    number: i + 1,
  }))

  // Fetch chapter info
  chapterInfo = await fetchChapterInfo(chapterId!)

  // Fetch manga title
  try {
    const manga = await fetchMangaDetail(mangaId!)
    mangaTitle = manga?.attributes?.title?.en 
      || manga?.attributes?.title?.ja 
      || Object.values(manga?.attributes?.title || {})[0] 
      || ''
  } catch {
    // Title fetch failed, continue without it
  }
} catch (e: any) {
  error = e.message || 'Failed to load chapter'
}

const chapterNum = chapterInfo?.chapter || '?'
const chapterTitle = chapterInfo?.title || ''
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Chapter {chapterNum} - {mangaTitle} | YummyScans</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        background: #0f0f0f;
        color: #ffffff;
        font-family: 'Inter', system-ui, sans-serif;
        min-height: 100vh;
      }
      .reader-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 0;
      }
      .reader-container img {
        width: 100%;
        height: auto;
        display: block;
      }
      .top-bar {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(15, 15, 15, 0.9);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(255,255,255,0.1);
        padding: 12px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .top-bar a {
        color: #ffffff;
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .top-bar .title {
        font-size: 14px;
        font-weight: 600;
        text-align: center;
        flex: 1;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .nav-buttons {
        position: fixed;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 50;
        display: flex;
        gap: 12px;
        background: rgba(15, 15, 15, 0.9);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.15);
        border-radius: 50px;
        padding: 8px 16px;
      }
      .nav-buttons a {
        color: #ffffff;
        text-decoration: none;
        font-size: 13px;
        font-weight: 500;
        padding: 8px 16px;
        border-radius: 50px;
        transition: background 0.2s;
        display: flex;
        align-items: center;
        gap: 6px;
      }
      .nav-buttons a:hover {
        background: rgba(255,255,255,0.1);
      }
      .page-counter {
        font-size: 12px;
        color: rgba(255,255,255,0.5);
        text-align: center;
        padding: 16px;
      }
      .error-page {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        text-align: center;
        padding: 24px;
      }
      .error-page h1 { font-size: 24px; font-weight: 600; margin-bottom: 12px; }
      .error-page p { font-size: 14px; color: rgba(255,255,255,0.6); margin-bottom: 24px; }
      .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #fff;
        background: rgba(255,255,255,0.1);
        padding: 10px 20px;
        border-radius: 50px;
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
      }
      .btn-back:hover {
        background: rgba(255,255,255,0.15);
      }
    </style>
  </head>
  <body>

    {error || pages.length === 0 ? (
      <div class="error-page">
        <h1>Chapter Tidak Ditemukan</h1>
        <p>{error || 'Halaman chapter tidak tersedia.'}</p>
        <a href={`/manga/${mangaId}`} class="btn-back">
          <ArrowLeft style="width:16px;height:16px" /> Kembali
        </a>
      </div>
    ) : (
      <>
        {/* Top Bar */}
        <div class="top-bar">
          <a href={`/manga/${mangaId}`}>
            <ArrowLeft style="width:16px;height:16px" /> Kembali
          </a>
          <div class="title">
            {mangaTitle ? `${mangaTitle} - ` : ''}Chapter {chapterNum}
            {chapterTitle && `: ${chapterTitle}`}
          </div>
          <div style="width:80px"></div>
        </div>

        {/* Pages */}
        <div class="reader-container">
          {pages.map((page) => (
            <div>
              <img
                src={page.url}
                alt={`Page ${page.number}`}
                loading={page.number > 2 ? 'lazy' : 'eager'}
              />
              <div class="page-counter">Page {page.number} / {pages.length}</div>
            </div>
          ))}
        </div>

        {/* Floating Nav */}
        <div class="nav-buttons">
          <a href={`/manga/${mangaId}`}>
            <ArrowLeft style="width:14px;height:14px" /> Daftar Chapter
          </a>
        </div>
      </>
    )}

  </body>
</html>

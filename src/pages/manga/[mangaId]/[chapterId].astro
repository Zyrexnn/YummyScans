---
import { fetchDetail, fetchChapterByUrl, BASE_URL } from '../../../lib/komiku'

const { mangaId, chapterId } = Astro.params

let pages: { url: string; number: number }[] = []
let mangaTitle = ''
let chapterNum = ''
let chapterTitle = ''
let error: string | null = null
let prevChapterSlug: string | null = null
let nextChapterSlug: string | null = null
let coverUrl: string | null = null
let mangaType = ''

try {
  const chapterUrl = `${BASE_URL}/komik/${mangaId}/${chapterId}/`
  const [chapterData, detail] = await Promise.all([
    fetchChapterByUrl(chapterUrl),
    fetchDetail(mangaId!).catch(() => null)
  ])

  if (!chapterData.pages || chapterData.pages.length === 0) {
    throw new Error('No pages found')
  }

  pages = chapterData.pages.map((url: string, i: number) => ({
    url,
    number: i + 1,
  }))

  chapterTitle = chapterData.title || ''
  mangaTitle = detail?.title || mangaId?.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ') || ''
  coverUrl = detail?.coverUrl || null
  mangaType = detail?.type || ''

  const chapterMatch = chapterId?.match(/chapter-([\d.]+)/)
  chapterNum = chapterMatch ? chapterMatch[1] : '?'

  if (detail?.chapters) {
    const currentIdx = detail.chapters.findIndex(ch => ch.slug === chapterId)
    if (currentIdx > 0) prevChapterSlug = detail.chapters[currentIdx - 1].slug
    if (currentIdx < detail.chapters.length - 1) nextChapterSlug = detail.chapters[currentIdx + 1].slug
  }
} catch (e: any) {
  error = e.message || 'Failed to load chapter'
}

const backUrl = `/manga/${mangaId}`
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Chapter {chapterNum} - {mangaTitle} | YummyScans</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        background: #000000;
        color: #ffffff;
        font-family: 'Inter', system-ui, sans-serif;
        min-height: 100vh;
      }
      .reader-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 0 0 80px 0;
      }
      .reader-container img {
        width: 100%;
        height: auto;
        display: block;
      }
      .top-bar {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(0, 0, 0, 0.92);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid rgba(255,255,255,0.08);
        padding: 0;
        display: flex;
        align-items: stretch;
      }
      .top-bar a.back-link {
        color: #ffffff;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: opacity 0.2s;
        padding: 12px 16px;
        flex-shrink: 0;
        border-right: 1px solid rgba(255,255,255,0.08);
      }
      .top-bar a.back-link:hover { opacity: 0.7; }
      .top-bar .title {
        font-size: 13px;
        font-weight: 600;
        line-height: 1.3;
        color: rgba(255,255,255,0.9);
        padding: 10px 16px;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        display: flex;
        align-items: center;
        flex: 1;
      }
      .top-bar .title .chapter-label {
        color: #ffffff;
        font-weight: 700;
        flex-shrink: 0;
        margin-left: 4px;
      }
      .fav-btn {
        background: none;
        border: none;
        color: rgba(255,255,255,0.5);
        cursor: pointer;
        padding: 8px 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        flex-shrink: 0;
        border-left: 1px solid rgba(255,255,255,0.08);
      }
      .fav-btn:hover { color: #ef4444; }
      .fav-btn.active { color: #ef4444; }
      .fav-btn svg { width: 20px; height: 20px; transition: transform 0.2s; }
      .fav-btn:hover svg { transform: scale(1.15); }
      .fav-btn.active svg { fill: #ef4444; }
      .nav-buttons {
        position: fixed;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 50;
        display: flex;
        gap: 8px;
        background: rgba(0, 0, 0, 0.92);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 50px;
        padding: 8px 12px;
      }
      .nav-buttons a {
        color: #ffffff;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        padding: 8px 20px;
        border-radius: 50px;
        transition: background 0.2s, opacity 0.2s;
        display: flex;
        align-items: center;
        gap: 6px;
        white-space: nowrap;
      }
      .nav-buttons a:hover { background: rgba(255,255,255,0.12); }
      .nav-buttons a.disabled {
        opacity: 0.3;
        pointer-events: none;
      }
      .page-counter {
        font-size: 12px;
        font-weight: 600;
        color: rgba(255,255,255,0.4);
        text-align: center;
        padding: 16px;
      }
      .error-page {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        text-align: center;
        padding: 24px;
      }
      .error-page h1 { font-size: 24px; font-weight: 700; margin-bottom: 12px; color: #ffffff; }
      .error-page p { font-size: 14px; font-weight: 500; color: rgba(255,255,255,0.6); margin-bottom: 24px; max-width: 400px; }
      .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #ffffff;
        background: rgba(255,255,255,0.1);
        padding: 10px 24px;
        border-radius: 50px;
        text-decoration: none;
        font-size: 14px;
        font-weight: 600;
        transition: background 0.2s;
      }
      .btn-back:hover { background: rgba(255,255,255,0.18); }
      .nav-buttons a .btn-label { display: inline; }
      @media (max-width: 640px) {
        .top-bar a.back-link { font-size: 12px; padding: 10px 12px; gap: 4px; }
        .top-bar a.back-link svg { width: 14px; height: 14px; }
        .top-bar .title { font-size: 12px; padding: 8px 12px; }
        .nav-buttons { bottom: 16px; padding: 6px 8px; gap: 4px; }
        .nav-buttons a { font-size: 12px; padding: 6px 10px; }
        .nav-buttons a .btn-label { display: none; }
      }
    </style>
  </head>
  <body
    data-manga-slug={mangaId}
    data-chapter-slug={chapterId}
    data-chapter-num={chapterNum}
    data-manga-title={mangaTitle}
    data-cover-url={coverUrl}
    data-manga-type={mangaType}
  >

    {error || pages.length === 0 ? (
      <div class="error-page">
        <h1>Chapter Tidak Ditemukan</h1>
        <p>{error || 'Halaman chapter tidak tersedia.'}</p>
        <a href={backUrl} class="btn-back">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
          Kembali
        </a>
      </div>
    ) : (
      <>
        <div class="top-bar">
          <a href={backUrl} class="back-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
            Kembali
          </a>
          <div class="title">
            <span class="chapter-label">Ch.{chapterNum}</span>
          </div>
          <button id="reader-fav-btn" class="fav-btn" aria-label="Tambah ke favorit">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </button>
        </div>

        <div class="reader-container">
          {pages.map((page) => (
            <div>
              <img
                src={page.url}
                alt={`Page ${page.number}`}
                loading={page.number > 1 ? 'lazy' : 'eager'}
              />
              <div class="page-counter">{page.number} / {pages.length}</div>
              <div data-page="{page.number}"></div>
            </div>
          ))}
        </div>

        <div class="nav-buttons">
          <a href={prevChapterSlug ? `/manga/${mangaId}/${prevChapterSlug}` : '#'} class={!prevChapterSlug ? 'disabled' : ''}>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
            <span class="btn-label">Prev</span>
          </a>
          <a href={backUrl}>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            <span class="btn-label">Daftar</span>
          </a>
          <a href={nextChapterSlug ? `/manga/${mangaId}/${nextChapterSlug}` : '#'} class={!nextChapterSlug ? 'disabled' : ''}>
            <span class="btn-label">Next</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
          </a>
        </div>
      </>
    )}

    <script is:inline>
      // History tracking & page resume for reader
      (function() {
        const body = document.body;
        const mangaSlug = body.getAttribute('data-manga-slug') || '';
        const chapterSlug = body.getAttribute('data-chapter-slug') || '';
        const chapterNum = body.getAttribute('data-chapter-num') || '';
        const mangaTitle = body.getAttribute('data-manga-title') || '';
        const coverUrl = body.getAttribute('data-cover-url') || '';
        const type = body.getAttribute('data-manga-type') || '';

        if (!mangaSlug || !chapterSlug) return;

        // Initialize history from localStorage
        function getHistory() {
          try {
            return JSON.parse(localStorage.getItem('yummy:history') || '[]');
          } catch { return []; }
        }
        function saveHistory(h) {
          try { localStorage.setItem('yummy:history', JSON.stringify(h)); } catch {}
        }

        // Record this chapter read
        function recordHistory() {
          const hist = getHistory();
          const existingIdx = hist.findIndex(h => h.mangaSlug === mangaSlug && h.chapterSlug === chapterSlug);
          const entry = {
            mangaSlug, mangaTitle, coverUrl, type,
            chapterSlug, chapterNum,
            page: 1,
            readAt: Date.now()
          };
          if (existingIdx >= 0) {
            hist[existingIdx] = { ...hist[existingIdx], ...entry, page: hist[existingIdx].page || 1, readAt: Date.now() };
          } else {
            hist.unshift(entry);
          }
          if (hist.length > 50) hist.length = 50;
          saveHistory(hist);
        }

        // Update current page in history
        function updatePage(page) {
          const hist = getHistory();
          const idx = hist.findIndex(h => h.mangaSlug === mangaSlug && h.chapterSlug === chapterSlug);
          if (idx >= 0) {
            hist[idx].page = page;
            hist[idx].readAt = Date.now();
            saveHistory(hist);
          }
        }

        // Resume to last page
        function resumePage() {
          const hist = getHistory();
          const entry = hist.find(h => h.mangaSlug === mangaSlug && h.chapterSlug === chapterSlug);
          if (entry && entry.page && entry.page > 1) {
            const target = document.querySelector('[data-page="' + entry.page + '"]');
            if (target) {
              target.scrollIntoView({ behavior: 'instant', block: 'start' });
            }
          }
        }

        recordHistory();
        resumePage();

        // Track visible page via IntersectionObserver
        const pageElements = document.querySelectorAll('[data-page]');
        if (pageElements.length && 'IntersectionObserver' in window) {
          const observer = new IntersectionObserver((entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                const pageNum = parseInt(entry.target.getAttribute('data-page') || '1', 10);
                updatePage(pageNum);
              }
            }
          }, { rootMargin: '0px 0px -50% 0px', threshold: 0.5 });
          pageElements.forEach(el => observer.observe(el));
        }

        // Favorite button
        (function() {
          const btn = document.getElementById('reader-fav-btn');
          if (!btn) return;
          const slug = mangaSlug;
          const title = mangaTitle;
          const cover = coverUrl;
          const mangaType = type;

          function getFavs() {
            try { return JSON.parse(localStorage.getItem('yummy:favorites') || '[]'); }
            catch { return []; }
          }
          function saveFavs(f) {
            try { localStorage.setItem('yummy:favorites', JSON.stringify(f)); } catch {}
          }
          function isFav(slug) { return getFavs().some(f => f.slug === slug); }
          function updateBtn() {
            const fav = isFav(slug);
            btn.classList.toggle('active', fav);
            const svg = btn.querySelector('svg');
            if (svg) svg.setAttribute('fill', fav ? '#ef4444' : 'none');
            btn.setAttribute('aria-label', fav ? 'Hapus dari favorit' : 'Tambah ke favorit');
          }
          btn.addEventListener('click', function(e) {
            e.preventDefault();
            const favs = getFavs();
            const idx = favs.findIndex(f => f.slug === slug);
            if (idx >= 0) {
              favs.splice(idx, 1);
            } else {
              favs.push({ slug, title, coverUrl: cover, type: mangaType });
            }
            saveFavs(favs);
            updateBtn();
            // Notify other tabs
            try { localStorage.setItem('yummy:favorites:touch', Date.now().toString()); } catch {}
          });
          updateBtn();
        })();

        // Keyboard nav
        document.addEventListener('keydown', (e) => {
          const prevLink = document.querySelector('.nav-buttons a:nth-child(1)');
          const nextLink = document.querySelector('.nav-buttons a:nth-child(3)');
          if (e.key === 'ArrowLeft' && prevLink && !prevLink.classList.contains('disabled')) {
            window.location.href = prevLink.href;
          } else if (e.key === 'ArrowRight' && nextLink && !nextLink.classList.contains('disabled')) {
            window.location.href = nextLink.href;
          }
        });
      })();
    </script>

  </body>
</html>

---
import { fetchDetail, fetchChapterByUrl, BASE_URL } from '../../../lib/komiku'

const { mangaId, chapterId } = Astro.params

let pages: { url: string; number: number }[] = []
let mangaTitle = ''
let chapterNum = ''
let chapterTitle = ''
let error: string | null = null
let prevChapterSlug: string | null = null
let nextChapterSlug: string | null = null

try {
  const chapterUrl = `${BASE_URL}/komik/${mangaId}/${chapterId}/`
  const [chapterData, detail] = await Promise.all([
    fetchChapterByUrl(chapterUrl),
    fetchDetail(mangaId!).catch(() => null)
  ])

  if (!chapterData.pages || chapterData.pages.length === 0) {
    throw new Error('No pages found')
  }

  pages = chapterData.pages.map((url: string, i: number) => ({
    url,
    number: i + 1,
  }))

  chapterTitle = chapterData.title || ''
  mangaTitle = detail?.title || mangaId?.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ') || ''

  const chapterMatch = chapterId?.match(/chapter-([\d.]+)/)
  chapterNum = chapterMatch ? chapterMatch[1] : '?'

  if (detail?.chapters) {
    const currentIdx = detail.chapters.findIndex(ch => ch.slug === chapterId)
    if (currentIdx > 0) prevChapterSlug = detail.chapters[currentIdx - 1].slug
    if (currentIdx < detail.chapters.length - 1) nextChapterSlug = detail.chapters[currentIdx + 1].slug
  }
} catch (e: any) {
  error = e.message || 'Failed to load chapter'
}

const backUrl = `/manga/${mangaId}`
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Chapter {chapterNum} - {mangaTitle} | YummyScans</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        background: #000000;
        color: #ffffff;
        font-family: 'Inter', system-ui, sans-serif;
        min-height: 100vh;
      }
      .reader-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 0 0 80px 0;
      }
      .reader-container img {
        width: 100%;
        height: auto;
        display: block;
      }
      .top-bar {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(0, 0, 0, 0.92);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid rgba(255,255,255,0.08);
        padding: 0;
        display: flex;
        align-items: stretch;
      }
      .top-bar a.back-link {
        color: #ffffff;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: opacity 0.2s;
        padding: 12px 16px;
        flex-shrink: 0;
        border-right: 1px solid rgba(255,255,255,0.08);
      }
      .top-bar a.back-link:hover { opacity: 0.7; }
      .top-bar .title {
        font-size: 13px;
        font-weight: 600;
        line-height: 1.3;
        color: rgba(255,255,255,0.9);
        padding: 10px 16px;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        display: flex;
        align-items: center;
      }
      .top-bar .title .chapter-label {
        color: #ffffff;
        font-weight: 700;
        flex-shrink: 0;
        margin-left: 4px;
      }
      .nav-buttons {
        position: fixed;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 50;
        display: flex;
        gap: 8px;
        background: rgba(0, 0, 0, 0.92);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 50px;
        padding: 8px 12px;
      }
      .nav-buttons a {
        color: #ffffff;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        padding: 8px 20px;
        border-radius: 50px;
        transition: background 0.2s, opacity 0.2s;
        display: flex;
        align-items: center;
        gap: 6px;
        white-space: nowrap;
      }
      .nav-buttons a:hover { background: rgba(255,255,255,0.12); }
      .nav-buttons a.disabled {
        opacity: 0.3;
        pointer-events: none;
      }
      .page-counter {
        font-size: 12px;
        font-weight: 600;
        color: rgba(255,255,255,0.4);
        text-align: center;
        padding: 16px;
      }
      .error-page {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        text-align: center;
        padding: 24px;
      }
      .error-page h1 { font-size: 24px; font-weight: 700; margin-bottom: 12px; color: #ffffff; }
      .error-page p { font-size: 14px; font-weight: 500; color: rgba(255,255,255,0.6); margin-bottom: 24px; max-width: 400px; }
      .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #ffffff;
        background: rgba(255,255,255,0.1);
        padding: 10px 24px;
        border-radius: 50px;
        text-decoration: none;
        font-size: 14px;
        font-weight: 600;
        transition: background 0.2s;
      }
      .btn-back:hover { background: rgba(255,255,255,0.18); }
      .nav-buttons a .btn-label { display: inline; }
      @media (max-width: 640px) {
        .top-bar a.back-link { font-size: 12px; padding: 10px 12px; gap: 4px; }
        .top-bar a.back-link svg { width: 14px; height: 14px; }
        .top-bar .title { font-size: 12px; padding: 8px 12px; }
        .nav-buttons { bottom: 16px; padding: 6px 8px; gap: 4px; }
        .nav-buttons a { font-size: 12px; padding: 6px 10px; }
        .nav-buttons a .btn-label { display: none; }
      }
    </style>
  </head>
  <body>

    {error || pages.length === 0 ? (
      <div class="error-page">
        <h1>Chapter Tidak Ditemukan</h1>
        <p>{error || 'Halaman chapter tidak tersedia.'}</p>
        <a href={backUrl} class="btn-back">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
          Kembali
        </a>
      </div>
    ) : (
      <>
        <div class="top-bar">
          <a href={backUrl} class="back-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
            Kembali
          </a>
          <div class="title">
            <span class="chapter-label">Ch.{chapterNum}</span>
          </div>
        </div>

        <div class="reader-container">
          {pages.map((page) => (
            <div>
              <img
                src={page.url}
                alt={`Page ${page.number}`}
                loading={page.number > 1 ? 'lazy' : 'eager'}
              />
              <div class="page-counter">{page.number} / {pages.length}</div>
            </div>
          ))}
        </div>

        <div class="nav-buttons">
          <a href={prevChapterSlug ? `/manga/${mangaId}/${prevChapterSlug}` : '#'} class={!prevChapterSlug ? 'disabled' : ''}>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
            <span class="btn-label">Prev</span>
          </a>
          <a href={backUrl}>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            <span class="btn-label">Daftar</span>
          </a>
          <a href={nextChapterSlug ? `/manga/${mangaId}/${nextChapterSlug}` : '#'} class={!nextChapterSlug ? 'disabled' : ''}>
            <span class="btn-label">Next</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
          </a>
        </div>
      </>
    )}

    <script>
      document.addEventListener('keydown', (e) => {
        const prevLink = document.querySelector('.nav-buttons a:nth-child(1)') as HTMLAnchorElement
        const nextLink = document.querySelector('.nav-buttons a:nth-child(3)') as HTMLAnchorElement
        if (e.key === 'ArrowLeft' && prevLink && !prevLink.classList.contains('disabled')) {
          window.location.href = prevLink.href
        } else if (e.key === 'ArrowRight' && nextLink && !nextLink.classList.contains('disabled')) {
          window.location.href = nextLink.href
        }
      })
    </script>

  </body>
</html>

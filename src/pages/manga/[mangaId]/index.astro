---
import EditorialLayout from '../../../layouts/EditorialLayout.astro'
import { Badge } from '../../../components/ui/badge'
import { ArrowLeft, BookOpen, User, Calendar, ArrowRight, Clock } from 'lucide-react'
import { fetchDetail } from '../../../lib/komiku'

const { mangaId } = Astro.params

let chapters: any[] = []
let coverUrl: string | null = null
let title = 'Unknown'
let description = ''
let status = 'unknown'
let authorName = ''
let genres: string[] = []
let error: string | null = null
let mangaType = ''

try {
  const detail = await fetchDetail(mangaId!)
  title = detail.title
  coverUrl = detail.coverUrl || null
  description = detail.synopsis
  status = detail.status
  genres = detail.genres
  authorName = detail.author
  mangaType = detail.type
  chapters = detail.chapters.map(ch => ({
    id: ch.slug,
    title: ch.title,
    slug: ch.slug,
    attributes: {
      chapter: ch.slug.match(/chapter-([\d.]+)/)?.[1] || '?',
      title: ch.title,
    }
  }))
} catch (e: any) {
  error = e.message || 'Failed to load manga'
}

const firstChapter = chapters.find(ch => {
  const num = parseFloat(ch.attributes?.chapter || ch.slug?.match(/chapter-([\d.]+)/)?.[1] || '0')
  return num > 0
}) || chapters[0]

const latestChapter = chapters.length > 0 ? chapters[chapters.length - 1] : null
---

<EditorialLayout title={`${title} - YummyScans`}>

  {error ? (
    <section class="section-spacing bg-background">
      <div class="max-w-[1280px] mx-auto px-6 text-center">
        <div class="w-20 h-20 bg-secondary rounded-full flex items-center justify-center mx-auto mb-6">
          <BookOpen class="w-10 h-10 text-muted-foreground" />
        </div>
        <h1 class="text-headline mb-3">Manga Tidak Ditemukan</h1>
        <p class="text-body-sm text-muted-foreground mb-8">{error}</p>
        <a href="/" class="yummy-btn-secondary inline-flex items-center gap-2">
          <ArrowLeft class="w-4 h-4" /> Kembali ke Beranda
        </a>
      </div>
    </section>
  ) : (
    <>
      <div class="max-w-[1280px] mx-auto px-6 py-4">
        <a href="/" class="inline-flex items-center gap-2 text-sm font-medium text-muted-foreground hover:text-foreground transition-colors no-underline">
          <ArrowLeft class="w-4 h-4" /> Kembali
        </a>
      </div>

      <section class="pb-8 bg-background">
        <div class="max-w-[1280px] mx-auto px-6">
          <div class="flex flex-col md:flex-row gap-8 md:gap-12">

            <div class="w-full md:w-[320px] flex-shrink-0">
              <div class="aspect-[3/4] rounded-[16px] overflow-hidden bg-secondary">
                {coverUrl ? (
                  <img src={coverUrl} alt={title} class="w-full h-full object-cover" loading="eager" />
                ) : (
                  <div class="w-full h-full flex items-center justify-center">
                    <BookOpen class="w-16 h-16 text-muted-foreground" />
                  </div>
                )}
              </div>
            </div>

            <div class="flex-1">
              <div class="flex flex-wrap items-center gap-2 mb-4">
                <Badge variant={status === 'ongoing' ? 'default' : 'secondary'}>
                  {status === 'ongoing' ? 'Ongoing' : status === 'completed' ? 'Tamat' : status === 'hiatus' ? 'Hiatus' : status}
                </Badge>
                {mangaType && (
                  <Badge variant="outline" class="text-xs font-mono uppercase tracking-wider">
                    {mangaType}
                  </Badge>
                )}
              </div>

              <h1 class="text-display-lg mb-4">{title}</h1>

              <div class="flex flex-wrap gap-4 mb-6 text-sm text-muted-foreground">
                {authorName && (
                  <div class="flex items-center gap-1.5">
                    <User class="w-4 h-4" />
                    <span>{authorName}</span>
                  </div>
                )}
                <div class="flex items-center gap-1.5">
                  <BookOpen class="w-4 h-4" />
                  <span>{chapters.length} Chapter</span>
                </div>
                {latestChapter && (
                  <div class="flex items-center gap-1.5">
                    <Clock class="w-4 h-4" />
                    <span>Ch. {latestChapter.attributes?.chapter || '?'}</span>
                  </div>
                )}
              </div>

              {genres.length > 0 && (
                <div class="flex flex-wrap gap-2 mb-6">
                  {genres.map((genre: string) => (
                    <a
                      href={`/genre/${genre.toLowerCase().replace(/\s+/g, '-')}`}
                      class="text-xs font-mono uppercase tracking-wider px-3 py-1.5 rounded-full bg-secondary text-foreground hover:bg-primary hover:text-primary-foreground transition-colors no-underline"
                    >
                      {genre}
                    </a>
                  ))}
                </div>
              )}

              {description && (
                <div class="mb-8">
                  <h3 class="text-headline mb-3">Sinopsis</h3>
                  <p class="text-body-sm text-muted-foreground leading-relaxed">
                    {description.length > 500 ? description.slice(0, 500) + '...' : description}
                  </p>
                </div>
              )}

              <div class="flex flex-wrap gap-3">
                {firstChapter && (
                  <a
                    href={`/manga/${mangaId}/${firstChapter.slug || firstChapter.id}`}
                    class="yummy-btn-primary inline-flex items-center gap-2"
                  >
                    Baca Chapter 1
                    <ArrowRight class="w-4 h-4" />
                  </a>
                )}
                {latestChapter && latestChapter !== firstChapter && (
                  <a
                    href={`/manga/${mangaId}/${latestChapter.slug || latestChapter.id}`}
                    class="yummy-btn-secondary inline-flex items-center gap-2"
                  >
                    Chapter Terbaru
                    <ArrowRight class="w-4 h-4" />
                  </a>
                )}
              </div>
            </div>
          </div>
        </div>
      </section>

      {chapters.length > 0 && (
        <section class="pb-16 bg-background">
          <div class="max-w-[1280px] mx-auto px-6">
            <div class="flex items-center justify-between mb-6">
              <h2 class="text-headline">Daftar Chapter</h2>
              <span class="text-sm text-muted-foreground">{chapters.length} chapter</span>
            </div>
            <div class="border border-border rounded-[12px] overflow-hidden">
              {chapters.map((ch: any, i: number) => {
                const chSlug = ch.slug || ch.id
                const chNum = ch.attributes?.chapter || chSlug?.match(/chapter-([\d.]+)/)?.[1] || '?'
                const chTitle = ch.attributes?.title || ''
                return (
                  <a
                    href={`/manga/${mangaId}/${chSlug}`}
                    class={`flex items-center justify-between px-5 py-4 hover:bg-secondary transition-colors no-underline text-foreground border-b border-border last:border-b-0 ${i % 2 === 0 ? 'bg-background' : 'bg-secondary/30'}`}
                  >
                    <div class="flex items-center gap-3">
                      <span class="text-sm font-semibold min-w-[60px]">Ch. {chNum}</span>
                      {chTitle && chTitle !== `Chapter ${chNum}` && (
                        <span class="text-sm text-muted-foreground hidden sm:inline truncate max-w-[300px]">- {chTitle}</span>
                      )}
                    </div>
                    <span class="text-xs text-muted-foreground flex items-center gap-1">
                      Baca
                      <ArrowRight class="w-3 h-3" />
                    </span>
                  </a>
                )
              })}
            </div>
          </div>
        </section>
      )}

      {chapters.length === 0 && !error && (
        <section class="pb-16 bg-background">
          <div class="max-w-[1280px] mx-auto px-6 text-center">
            <p class="text-muted-foreground">Belum ada chapter.</p>
          </div>
        </section>
      )}
    </>
  )}

</EditorialLayout>

---
import EditorialLayout from '../../../layouts/EditorialLayout.astro'
import { Badge } from '../../../components/ui/badge'
import { ArrowLeft, BookOpen, User, Calendar, ArrowRight, Clock } from 'lucide-react'
import { fetchDetail, fetchGenreManga } from '../../../lib/komiku'

const { mangaId } = Astro.params

let chapters: any[] = []
let coverUrl: string | null = null
let title = 'Unknown'
let description = ''
let status = 'unknown'
let authorName = ''
let genres: string[] = []
let error: string | null = null
let mangaType = ''
let recommendations: { title: string; slug: string; coverUrl: string; type: string; chapter: string }[] = []

try {
  const detail = await fetchDetail(mangaId!)
  title = detail.title
  coverUrl = detail.coverUrl || null
  description = detail.synopsis
  status = detail.status
  genres = detail.genres
  authorName = detail.author
  mangaType = detail.type
  chapters = detail.chapters.map(ch => ({
    id: ch.slug,
    title: ch.title,
    slug: ch.slug,
    num: parseFloat(ch.slug.match(/chapter-([\d.]+)/i)?.[1] || ch.slug.match(/(\d+(?:\.\d+)?)/)?.[1] || '0'),
    attributes: {
      chapter: ch.slug.match(/chapter-([\d.]+)/i)?.[1] || ch.slug.match(/(\d+(?:\.\d+)?)/)?.[1] || '?',
      title: ch.title,
    }
  }))
  chapters.sort((a, b) => a.num - b.num)

  if (genres.length > 0) {
    try {
      const genreSlugs = genres.slice(0, 3).map(g => g.toLowerCase().replace(/\s+/g, '-'))
      const fetches = await Promise.allSettled(
        genreSlugs.map(slug => fetchGenreManga(slug, 1))
      )

      const seen = new Map<string, { title: string; slug: string; coverUrl: string; type: string; chapter: string; hits: number }>()
      for (const result of fetches) {
        if (result.status !== 'fulfilled') continue
        for (const m of result.value) {
          if (m.slug === mangaId) continue
          const existing = seen.get(m.slug)
          if (existing) {
            existing.hits++
          } else {
            seen.set(m.slug, { title: m.title, slug: m.slug, coverUrl: m.coverUrl, type: m.type, chapter: m.chapter, hits: 1 })
          }
        }
      }

      recommendations = [...seen.values()]
        .sort((a, b) => b.hits - a.hits)
        .slice(0, 12)
        .map(({ hits, ...rest }) => rest)
    } catch {}
  }
} catch (e: any) {
  error = e.message || 'Failed to load manga'
}

const firstChapter = chapters.length > 0 ? chapters[0] : null
const latestChapter = chapters.length > 0 ? chapters[chapters.length - 1] : null
---

<EditorialLayout title={`${title} - YummyScans`}>

  {error ? (
    <section class="section-spacing bg-background">
      <div class="max-w-[1280px] mx-auto px-6 text-center">
        <div class="w-20 h-20 bg-secondary rounded-full flex items-center justify-center mx-auto mb-6">
          <BookOpen class="w-10 h-10 text-muted-foreground" />
        </div>
        <h1 class="text-headline mb-3">Manga Tidak Ditemukan</h1>
        <p class="text-body-sm text-muted-foreground mb-8">{error}</p>
        <button onclick="history.back()" class="yummy-btn-secondary inline-flex items-center gap-2">
          <ArrowLeft class="w-4 h-4" /> Kembali
        </button>
      </div>
    </section>
  ) : (
    <>
      <div class="max-w-[1280px] mx-auto px-6 py-4">
        <button onclick="history.back()" class="inline-flex items-center gap-2 text-sm font-medium text-muted-foreground hover:text-foreground transition-colors bg-transparent border-0 cursor-pointer p-0">
          <ArrowLeft class="w-4 h-4" /> Kembali
        </button>
      </div>

      <section class="pb-8 bg-background">
        <div class="max-w-[1280px] mx-auto px-6">
          <div class="flex flex-col md:flex-row gap-8 md:gap-12">

            <div class="w-full sm:w-[200px] md:w-[240px] lg:w-[280px] flex-shrink-0">
              <div class="aspect-[3/4] rounded-lg overflow-hidden bg-secondary">
                {coverUrl ? (
                  <img src={coverUrl} alt={title} class="w-full h-full object-cover" loading="eager" />
                ) : (
                  <div class="w-full h-full flex items-center justify-center">
                    <BookOpen class="w-12 h-12 text-muted-foreground" />
                  </div>
                )}
              </div>
            </div>

            <div class="flex-1">
              <div class="flex flex-wrap items-center gap-2 mb-4">
                <Badge variant={status === 'ongoing' ? 'default' : 'secondary'}>
                  {status === 'ongoing' ? 'Ongoing' : status === 'completed' ? 'Tamat' : status === 'hiatus' ? 'Hiatus' : status}
                </Badge>
                {mangaType && (
                  <Badge variant="outline" class="text-xs font-mono uppercase tracking-wider">
                    {mangaType}
                  </Badge>
                )}
              </div>

              <h1 class="text-display-lg mb-4">{title}</h1>

              <div class="flex flex-wrap gap-4 mb-6 text-sm text-muted-foreground">
                {authorName && (
                  <div class="flex items-center gap-1.5">
                    <User class="w-4 h-4" />
                    <span>{authorName}</span>
                  </div>
                )}
                <div class="flex items-center gap-1.5">
                  <BookOpen class="w-4 h-4" />
                  <span>{chapters.length} Chapter</span>
                </div>
                {latestChapter && (
                  <div class="flex items-center gap-1.5">
                    <Clock class="w-4 h-4" />
                    <span>Ch. {latestChapter.attributes?.chapter || '?'}</span>
                  </div>
                )}
              </div>

              {genres.length > 0 && (
                <div class="flex flex-wrap gap-2 mb-6">
                  {genres.map((genre: string) => (
                    <a
                      href={`/genre/${genre.toLowerCase().replace(/\s+/g, '-')}`}
                      class="text-xs font-mono uppercase tracking-wider px-3 py-1.5 rounded-full bg-secondary text-foreground hover:bg-primary hover:text-primary-foreground transition-colors no-underline"
                    >
                      {genre}
                    </a>
                  ))}
                </div>
              )}

              {description && (
                <div class="mb-8">
                  <h3 class="text-headline mb-3">Sinopsis</h3>
                  <p class="text-body-sm text-muted-foreground leading-relaxed">
                    {description.length > 500 ? description.slice(0, 500) + '...' : description}
                  </p>
                </div>
              )}

              <div class="flex flex-wrap gap-3">
                {firstChapter && (
                  <a
                    href={`/manga/${mangaId}/${firstChapter.slug || firstChapter.id}`}
                    class="yummy-btn-primary inline-flex items-center gap-2"
                  >
                    Baca Chapter {firstChapter.num || 1}
                    <ArrowRight class="w-4 h-4" />
                  </a>
                )}
                {latestChapter && latestChapter !== firstChapter && (
                  <a
                    href={`/manga/${mangaId}/${latestChapter.slug || latestChapter.id}`}
                    class="yummy-btn-secondary inline-flex items-center gap-2"
                  >
                    Chapter Terbaru
                    <ArrowRight class="w-4 h-4" />
                  </a>
                )}
              </div>
            </div>
          </div>
        </div>
      </section>

      {chapters.length > 0 && (() => {
        const INITIAL_SHOW = 30
        const chapterData = chapters.map((ch: any) => {
          const chSlug = ch.slug || ch.id
          const chNum = ch.num ?? parseFloat(chSlug.match(/chapter-([\d.]+)/i)?.[1] || chSlug.match(/(\d+(?:\.\d+)?)/)?.[1] || '0')
          return { slug: chSlug, num: chNum }
        })
        return (
          <section class="pb-16 bg-background">
            <div class="max-w-[1280px] mx-auto px-6">
              <div class="flex items-center justify-between mb-4">
                <h2 class="text-headline">Daftar Chapter</h2>
                <span class="text-xs text-muted-foreground bg-secondary rounded-full px-3 py-1">{chapters.length}</span>
              </div>

              <div class="rounded-xl border border-border p-3 md:p-4">
                <div id="chapter-grid" class="grid grid-cols-4 sm:grid-cols-6 md:grid-cols-8 lg:grid-cols-10 gap-1.5">
                  {chapterData.map((ch, i) => (
                    <a
                      href={`/manga/${mangaId}/${ch.slug}`}
                      class:list={[
                        "chapter-item flex items-center justify-center rounded-lg py-2 text-xs font-medium transition no-underline text-foreground hover:bg-foreground hover:text-background",
                        i >= INITIAL_SHOW ? "hidden" : "bg-secondary"
                      ]}
                      data-index={i}
                    >
                      {ch.num}
                    </a>
                  ))}
                </div>

                {chapters.length > INITIAL_SHOW && (
                  <div class="mt-3 text-center">
                    <button
                      id="chapter-toggle"
                      onclick="
                        const grid = document.getElementById('chapter-grid');
                        const items = grid.querySelectorAll('.chapter-item');
                        const btn = this;
                        const expanded = btn.dataset.expanded === '1';
                        items.forEach((el, i) => {
                          if (i >= 30) el.classList.toggle('hidden', expanded);
                        });
                        btn.dataset.expanded = expanded ? '0' : '1';
                        btn.textContent = expanded ? 'Lihat Semua Chapter' : 'Sembunyikan';
                        if (!expanded) grid.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                      "
                      data-expanded="0"
                      class="w-full py-2.5 rounded-lg bg-secondary text-sm font-medium text-foreground hover:bg-muted transition"
                    >
                      Lihat Semua Chapter
                    </button>
                  </div>
                )}
              </div>
            </div>
          </section>
        )
      })()}

      {chapters.length === 0 && !error && (
        <section class="pb-16 bg-background">
          <div class="max-w-[1280px] mx-auto px-6 text-center">
            <p class="text-muted-foreground">Belum ada chapter.</p>
          </div>
        </section>
      )}

      {recommendations.length > 0 && (
        <section class="pb-16 bg-background">
          <div class="max-w-[1280px] mx-auto px-6">
            <div class="flex items-center justify-between mb-5">
              <h2 class="text-headline">Kamu Mungkin Suka</h2>
              <a href={`/genre/${genres[0]?.toLowerCase().replace(/\s+/g, '-') || ''}`} class="text-xs text-muted-foreground hover:text-foreground transition">
                {genres[0]} &rarr;
              </a>
            </div>
            <p class="text-xs text-muted-foreground mb-4">Berdasarkan genre: {genres.join(', ')}</p>
            <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-6 gap-3 md:gap-4">
              {recommendations.map(m => (
                <a
                  href={`/manga/${m.slug}`}
                  class="group block"
                >
                  <div class="relative aspect-[3/4] overflow-hidden rounded-lg bg-secondary">
                    <img
                      src={m.coverUrl}
                      alt={m.title}
                      loading="lazy"
                      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                      onError={(e) => {
                        const t = e.target as HTMLImageElement
                        t.style.display = 'none'
                      }}
                    />
                    <span class="absolute right-1.5 top-1.5 flex h-4 w-4 items-center justify-center rounded bg-background text-[10px] leading-none shadow">
                      {m.type === 'Manhwa' ? '🇰🇷' : m.type === 'Manhua' ? '🇨🇳' : '🇯🇵'}
                    </span>
                    <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent p-2 pt-6">
                      <h3 class="line-clamp-2 text-[12px] font-bold leading-tight text-white">{m.title}</h3>
                      {m.chapter && <p class="mt-0.5 truncate text-[10px] text-white/50">{m.chapter}</p>}
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </section>
      )}
    </>
  )}

</EditorialLayout>
